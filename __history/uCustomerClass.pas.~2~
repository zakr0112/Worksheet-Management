unit uCustomerClass;


interface

uses
  System.SysUtils, System.Classes, System.Generics.Collections,
  FireDAC.Comp.Client, FireDAC.Stan.Param;

type
  TCustomer = class
  private
    FCustID: Integer;
    FCustName: string;
    FCustAddress: string;
    FCustPostcode: string;
    FCustTelephone: string;
    FCustEmail: string;
    FCustContact: string;
    FLastChanged: TDateTime;
  public
    property CustID: Integer read FCustID write FCustID;
    property CustName: string read FCustName write FCustName;
    property CustAddress: string read FCustAddress write FCustAddress;
    property CustPostcode: string read FCustPostcode write FCustPostcode;
    property CustTelephone: string read FCustTelephone write FCustTelephone;
    property CustEmail: string read FCustEmail write FCustEmail;
    property CustContact: string read FCustContact write FCustContact;
    property LastChanged: TDateTime read FLastChanged write FLastChanged;

    procedure InsertCustomer(AConnection: TFDConnection);
    procedure UpdateCustomer(AConnection: TFDConnection);
    procedure DeleteCustomer(AConnection: TFDConnection);
    class function GetCustomerByID(AConnection: TFDConnection; ACustID: Integer): TCustomer;
    class function GetAllCustomers(AConnection: TFDConnection): TList<TCustomer>;
  end;

implementation

{ TCustomer }

procedure TCustomer.InsertCustomer(AConnection: TFDConnection);
var
  qry: TFDQuery;
begin
  qry := TFDQuery.Create(nil);
  try
    qry.Connection := AConnection;
    qry.SQL.Text :=
      'INSERT INTO customers (custname, custaddress, custpostcode, custtelephone, custemail, custcontact, lastchanged) ' +
      'VALUES (:custname, :custaddress, :custpostcode, :custtelephone, :custemail, :custcontact, :lastchanged)';
    qry.ParamByName('custname').AsString := FCustName;
    qry.ParamByName('custaddress').AsString := FCustAddress;
    qry.ParamByName('custpostcode').AsString := FCustPostcode;
    qry.ParamByName('custtelephone').AsString := FCustTelephone;
    qry.ParamByName('custemail').AsString := FCustEmail;
    qry.ParamByName('custcontact').AsString := FCustContact;
    qry.ParamByName('lastchanged').AsDateTime := FLastChanged;
    qry.ExecSQL;
  finally
    qry.Free;
  end;
end;

procedure TCustomer.UpdateCustomer(AConnection: TFDConnection);
var
  qry: TFDQuery;
begin
  qry := TFDQuery.Create(nil);
  try
    qry.Connection := AConnection;
    qry.SQL.Text :=
      'UPDATE customers SET custname = :custname, custaddress = :custaddress, custpostcode = :custpostcode, ' +
      'custtelephone = :custtelephone, custemail = :custemail, custcontact = :custcontact, lastchanged = :lastchanged ' +
      'WHERE custid = :custid';
    qry.ParamByName('custid').AsInteger := FCustID;
    qry.ParamByName('custname').AsString := FCustName;
    qry.ParamByName('custaddress').AsString := FCustAddress;
    qry.ParamByName('custpostcode').AsString := FCustPostcode;
    qry.ParamByName('custtelephone').AsString := FCustTelephone;
    qry.ParamByName('custemail').AsString := FCustEmail;
    qry.ParamByName('custcontact').AsString := FCustContact;
    qry.ParamByName('lastchanged').AsDateTime := FLastChanged;
    qry.ExecSQL;
  finally
    qry.Free;
  end;
end;

procedure TCustomer.DeleteCustomer(AConnection: TFDConnection);
var
  qry: TFDQuery;
begin
  qry := TFDQuery.Create(nil);
  try
    qry.Connection := AConnection;
    qry.SQL.Text := 'DELETE FROM customers WHERE custid = :custid';
    qry.ParamByName('custid').AsInteger := FCustID;
    qry.ExecSQL;
  finally
    qry.Free;
  end;
end;

class function TCustomer.GetCustomerByID(AConnection: TFDConnection; ACustID: Integer): TCustomer;
var
  qry: TFDQuery;
begin
  Result := nil;
  qry := TFDQuery.Create(nil);
  try
    qry.Connection := AConnection;
    qry.SQL.Text := 'SELECT * FROM customers WHERE custid = :custid';
    qry.ParamByName('custid').AsInteger := ACustID;
    qry.Open;
    if not qry.Eof then
    begin
      Result := TCustomer.Create;
      Result.FCustID := qry.FieldByName('custid').AsInteger;
      Result.FCustName := qry.FieldByName('custname').AsString;
      Result.FCustAddress := qry.FieldByName('custaddress').AsString;
      Result.FCustPostcode := qry.FieldByName('custpostcode').AsString;
      Result.FCustTelephone := qry.FieldByName('custtelephone').AsString;
      Result.FCustEmail := qry.FieldByName('custemail').AsString;
      Result.FCustContact := qry.FieldByName('custcontact').AsString;
      Result.FLastChanged := qry.FieldByName('lastchanged').AsDateTime;
    end;
  finally
    qry.Free;
  end;
end;

class function TCustomer.GetAllCustomers(AConnection: TFDConnection): TList<TCustomer>;
var
  qry: TFDQuery;
  customer: TCustomer;
begin
  Result := TList<TCustomer>.Create;
  qry := TFDQuery.Create(nil);
  try
    qry.Connection := AConnection;
    qry.SQL.Text := 'SELECT * FROM customers ORDER BY custname';
    qry.Open;
    while not qry.Eof do
    begin
      customer := TCustomer.Create;
      customer.FCustID := qry.FieldByName('custid').AsInteger;
      customer.FCustName := qry.FieldByName('custname').AsString;
      customer.FCustAddress := qry.FieldByName('custaddress').AsString;
      customer.FCustPostcode := qry.FieldByName('custpostcode').AsString;
      customer.FCustTelephone := qry.FieldByName('custtelephone').AsString;
      customer.FCustEmail := qry.FieldByName('custemail').AsString;
      customer.FCustContact := qry.FieldByName('custcontact').AsString;
      customer.FLastChanged := qry.FieldByName('lastchanged').AsDateTime;
      Result.Add(customer);
      qry.Next;
    end;
  finally
    qry.Free;
  end;
end;

end.
