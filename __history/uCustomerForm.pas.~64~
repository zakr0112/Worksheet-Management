unit uCustomerForm;

interface

uses
  System.SysUtils, System.Types, System.UITypes, System.Classes, System.Variants,
  FMX.Types, FMX.Controls, FMX.Forms, FMX.Graphics, FMX.Dialogs, uDataModule,
  FireDAC.Stan.Intf, FireDAC.Stan.Option, FireDAC.Stan.Param,
  FireDAC.Stan.Error, FireDAC.DatS, FireDAC.Phys.Intf, FireDAC.DApt.Intf,
  FireDAC.Stan.Async, FireDAC.DApt, Data.DB, FireDAC.Comp.DataSet,
  FireDAC.Comp.Client, FMX.Layouts, FMX.TabControl, FMX.Memo.Types,
  FMX.StdCtrls, FMX.ScrollBox, FMX.Memo, FMX.Edit, FMX.Controls.Presentation,
  System.Rtti, FMX.ListView.Types, FMX.ListView.Appearances,
  FMX.ListView.Adapters.Base, FMX.ListView, FMX.DialogService.Async, FMX.DialogService,
  uCommon;

type
  TCustomerForm = class(TForm)
    qryCustomerlist: TFDQuery;
    TCcustomers: TTabControl;
    TIcustomerlist: TTabItem;
    TIcustomerdetails: TTabItem;
    gpanCustomer: TGridPanelLayout;
    Label1: TLabel;
    txtCustname: TEdit;
    Label3: TLabel;
    memCustaddress: TMemo;
    Label5: TLabel;
    txtCustpostcode: TEdit;
    Label7: TLabel;
    Label10: TLabel;
    Label13: TLabel;
    txtCusttelephone: TEdit;
    txtCustemail: TEdit;
    txtCustcontact: TEdit;
    Layout1: TLayout;
    spdSave: TSpeedButton;
    spdDelete: TSpeedButton;
    spdCancel: TSpeedButton;
    LVcustomers: TListView;
    qryCustomerFetch: TFDQuery;
    procedure FormCreate(Sender: TObject);
    procedure FormDestroy(Sender: TObject);
    procedure LVcustomersItemClickEx(const Sender: TObject; ItemIndex: Integer;
      const LocalClickPos: TPointF; const ItemObject: TListItemDrawable);
    procedure SpeedButton3Click(Sender: TObject);
    procedure spdDeleteClick(Sender: TObject);
  private
    function FetchCustomer(const Acustid: Integer): boolean;
    function DeleteCustomerRecord(const Acustid: integer): boolean;
    { Private declarations }
  public
    { Public declarations }
    procedure DisplayCustomerRecord();
    procedure ClearCustomerRecord();
    procedure PopulateCustomerList();
  end;

var
  CustomerForm: TCustomerForm;
  custid: integer;
  custname: string;

implementation

{$R *.fmx}

procedure TCustomerForm.FormCreate(Sender: TObject);
begin
  if not DM.FDlocal.Connected then
    DM.FDlocal.Open;
  PopulateCustomerList();
end;

procedure TCustomerForm.FormDestroy(Sender: TObject);
begin
  //
end;

procedure TCustomerForm.LVcustomersItemClickEx(const Sender: TObject;
  ItemIndex: Integer; const LocalClickPos: TPointF;
  const ItemObject: TListItemDrawable);
begin
  // Only continue if the right hand button clicked
  if (ItemIndex < 0) OR (ItemObject = NIL) then
    exit;

  if ItemObject is TListItemAccessory then
  begin
    custid := LVCustomers.Items.Item[itemindex].Tag;
     if FetchCustomer(custid) = false then
     // if FetchCustomer(-77) = false then   TESTING TO SEE IF THE MESSAGE WORKS
     begin
       ShowWarning('Unable to find the selected record');
       exit;
     end;
     // Now will move to the customer record tab
     TCcustomers.SetActiveTabWithTransitionAsync(TIcustomerDetails, TTabTransition.Slide, TTabTransitionDirection.Normal, nil);
  end;
end;

function TCustomerForm.FetchCustomer(const Acustid: Integer): boolean;
begin

  ClearCustomerRecord();
  // Try to fetch and display the customer
  try
     qryCustomerFetch.close;
     qryCustomerFetch.ParamByName('custid').AsInteger := Acustid;
     qryCustomerFetch.Open();
     if qryCustomerFetch.IsEmpty then
     begin
        exit(false);
     end;
     // Found the record, so display it
     custid := qryCustomerFetch.FieldByName('custid').AsInteger;
     custname := qryCustomerFetch.FieldByName('custname').AsString;
     txtCustname.Text := qryCustomerFetch.FieldByName('custname').AsString;
     memCustaddress.Text := qryCustomerFetch.FieldByName('custaddress').AsString;
     txtCustpostcode.Text := qryCustomerFetch.FieldByName('custpostcode').AsString;
     txtCusttelephone.Text := qryCustomerFetch.FieldByName('custtelephone').AsString;
     txtCustemail.Text := qryCustomerFetch.FieldByName('custemail').AsString;
     txtCustcontact.Text := qryCustomerFetch.FieldByName('custcontact').AsString;
     Result := true;
  finally
    qryCustomerFetch.Close;
  end;

end;

procedure TCustomerForm.PopulateCustomerList();
var
  LItem: TListViewItem;
begin
  // Read all the customers and display them


  LVCustomers.BeginUpdate;
  qryCustomerList.Open();
  try
    LVCustomers.Items.Clear;

    while not qryCustomerList.eof do
    begin

      // Add cust details to the list view
      LItem := LVCustomers.Items.Add;
      LItem.Tag := qryCustomerList.FieldByName('custid').AsInteger;
      LItem.Text := qryCustomerList.FieldByName('custname').AsString;



      qryCustomerList.Next;
    end;


  finally
    LVcustomers.EndUpdate;
    qryCustomerList.Close;
  end;
end;

procedure TCustomerForm.spdDeleteClick(Sender: TObject);
var
  MSG: string;
begin
  // Confirm they want to delete the current record
  if custid = -1 then
    exit;
  MSG := Format('Are you sure you want to delete %s?', [custname]);
  TDialogService.MessageDialog(MSG, TMsgDlgType.mtConfirmation, mbYesNo, TMsgDlgBtn.mbNo, 0,
    procedure (const AResult: TModalResult) begin
      if AResult = mrYes then
      begin
        try
          if DeleteCustomerRecord(custid) then
          begin
            PopulateCustomerList();
            ClearCustomerRecord();
          end;
        except
          on E: exception do
          begin
            ShowWarning('');
          end;
        end;
      end;
    end);

end;

procedure TCustomerForm.SpeedButton3Click(Sender: TObject);
begin
  // Go back to the list
  custid := -1;
  TCcustomers.SetActiveTabWithTransitionAsync(TIcustomerList, TTabTransition.Slide, TTabTransitionDirection.Reversed, nil);
  ClearCustomerRecord();
end;

procedure TCustomerForm.ClearCustomerRecord();
begin
  // Clear the record details
  txtCustname.Text := '';
  memCustaddress.Text := '';
  txtCustpostcode.Text := '';
  txtCusttelephone.Text := '';
  txtCustemail.Text := '';
  txtCustcontact.Text := '';
end;

procedure TCustomerForm.DisplayCustomerRecord();
begin
  // Display the record details
  ClearCustomerRecord();
  txtCustname.Text := qryCustomerFetch.FieldByName('custname').AsString;
  memCustaddress.Text := qryCustomerFetch.FieldByName('custaddress').AsString;
  txtCustpostcode.Text := qryCustomerFetch.FieldByName('custpostcode').AsString;
  txtCusttelephone.Text := qryCustomerFetch.FieldByName('custtelephone').AsString;
  txtCustemail.Text := qryCustomerFetch.FieldByName('custemail').AsString;
  txtCustcontact.Text := qryCustomerFetch.FieldByName('custcontact').AsString;
end;


function TCustomerForm.DeleteCustomerRecord(const Acustid: integer): boolean;
begin
   Result := true;
end;


end.
